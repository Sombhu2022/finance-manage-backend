# Zorvyn Finance App - Environment Configuration Example

# Server Settings
PORT=3000
NODE_ENV=development

# Database Settings (Neon/PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Authentication
# Use a strong random string for JWT secret
JWT_SECRET=your-super-secure-jwt-secret-here

# Security & Rate Limiting
# Window in milliseconds (e.g., 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# Email (SMTP) Configuration (e.g., Mailtrap, Gmail, etc.)
MAIL_SERVICE=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASS=your-app-specific-password
MAIL_FROM="Zorvyn Support" <support@zorvyn.com>
